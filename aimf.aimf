@M DEPS
<<[Cargo.toml]
[package]
name = "aimf-compiler"
version = "0.1.0"
edition = "2021"
description = "Compile GitHub projects into AIMF (AI Minimal Format) documents"
license = "MIT"

[dependencies]
tauri = { version = "2", features = [] }
tauri-plugin-dialog = "2"
tauri-plugin-fs = "2"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
walkdir = "2"
sha2 = "0.10"
hex = "0.4"
glob = "0.3"
chrono = "0.4"
rayon = "1.10"
clap = { version = "4", features = ["derive"], optional = true }
>>

