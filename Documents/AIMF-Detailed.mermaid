---
title: AIMF System — Detailed Architecture
---
graph TB
    %% ─── INPUT LAYER ───
    subgraph InputLayer["Input Layer"]
        direction LR
        LOCAL["Local Project Folder<br/>(.rs, .py, .ts, .md, .mermaid, etc.)"]
        GIT["Git Metadata<br/>(branch, commit, history)"]
        CONFIG["Compiler Config<br/>(max_hot, token_budget,<br/>ignore_patterns, custom_groups)"]
    end

    %% ─── COMPILER PIPELINE ───
    subgraph Pipeline["aimf-compiler Pipeline (Rust)"]
        direction TB

        subgraph Stage1["Stage 1: Scanner"]
            S1["walkdir traversal"]
            S2["Ignore filter<br/>(.git, node_modules, target, etc.)"]
            S3["SHA-256 hash<br/>(truncated 8 hex)"]
            S4["File metadata<br/>(path, size, abs_path)"]
            S1 --> S2 --> S3 --> S4
        end

        subgraph Stage2["Stage 2: Classifier"]
            C1["Extension matching<br/>(40+ languages)"]
            C2["ResourceType assignment<br/>(SRC/CFG/DOC/TEST/MRM/BIN/META/OTHER)"]
            C3["Entry point detection<br/>(main.rs, index.ts, app.py, etc.)"]
            C4["Semantic hint generation<br/>(max 60 chars)"]
            C1 --> C2 --> C3 --> C4
        end

        subgraph Stage3["Stage 3: Partitioner"]
            P1["Group assignment<br/>(glob pattern matching)"]
            P2["LoadWhen policy<br/>(always/on_edit/on_request/<br/>on_error/on_group/never)"]
            P3["Hot candidate scoring<br/>(Always > OnEdit, smaller first)"]
            P4["Hot strategy selection<br/>(Full/Summary/Head/Signature/Delta)"]
            P5["Shard decision<br/>(if resources > threshold)"]
            P1 --> P2 --> P3 --> P4 --> P5
        end

        subgraph Stage4["Stage 4: Emitter"]
            E1["@H: Header<br/>(V, R, HOT, GRP, REPO,<br/>BRANCH, COMMIT, TS, ROOT, SHARD)"]
            E2["@G: Groups<br/>(ID|Label|GlobPatterns)"]
            E3["@I: Index<br/>(ID|Type|LoadWhen|Path|<br/>Size|Hash|Group|Hint)"]
            E4["@M: Hot Memory"]
            E5["@C: Cold Blocks<br/>(optional)"]
            E1 --> E2 --> E3 --> E4 --> E5
        end

        S4 --> C1
        C4 --> P1
        P5 --> E1
    end

    %% ─── HOT STRATEGY ENGINE ───
    subgraph HotEngine["Hot Strategy Engine"]
        direction LR
        HS1["Full<br/>(< 2KB)"]
        HS2["Summary<br/>(2-20KB, LLM)"]
        HS3["Head(N)<br/>(> 20KB)"]
        HS4["Signature<br/>(fn/struct/class)"]
        HS5["Delta<br/>(git diff)"]
    end

    %% ─── HOT MEMORY DETAIL ───
    subgraph HotMemory["@M Hot Memory Contents"]
        direction LR
        CTX["CTX<br/>task, focus, cursor"]
        ARCH["ARCH<br/>project structure summary"]
        DEPS["DEPS<br/>dependency overview"]
        FILES["F1, F2, ...<br/>hot file payloads"]
        ERR["ERR<br/>error context"]
        DELTA["DELTA<br/>recent changes"]
    end

    %% ─── AIMF DOCUMENT ───
    subgraph AIMFDoc["AIMF Document (.aimf)"]
        direction TB
        DOC_H["@H — V:1 R:847 HOT:12 ..."]
        DOC_G["@G — G1|core|src/lib/** ..."]
        DOC_I["@I — F1|SRC|on_edit|src/main.rs|4096|a1b2c3d4|G1|entry point"]
        DOC_M["@M CTX — <<task=refactor;focus=G2>>"]
        DOC_C["@C F6 — <<pub struct Parser { ... }>>"]
        DOC_H --- DOC_G --- DOC_I --- DOC_M --- DOC_C
    end

    %% ─── SHARDING ───
    subgraph Sharding["Sharding (500+ files)"]
        direction LR
        SPINE["project.aimf<br/>(spine: @H+@G+@I+@M)"]
        SH1["project.G1.aimf<br/>(core group)"]
        SH2["project.G2.aimf<br/>(api group)"]
        SHN["project.GN.aimf<br/>(... more groups)"]
    end

    %% ─── READER SKILL ───
    subgraph ReaderSkill["aimf-reader Skill (Python)"]
        direction TB

        subgraph Parser["Parser (parse_aimf.py)"]
            direction LR
            PRS["Parse sections"]
            IDX["Index lookup"]
            SRCH["Search<br/>(path/hint)"]
            GRP["Group filter"]
            STATS["Token stats"]
        end

        subgraph Workflow["Skill Workflow"]
            W1["1. Find .aimf files"]
            W2["2. Load hot memory<br/>(CTX, ARCH, DEPS, files)"]
            W3["3. Navigate index<br/>(search by type/group/hint)"]
            W4["4. Load on demand<br/>(check @C then filesystem)"]
            W5["5. Track focus changes"]
            W1 --> W2 --> W3 --> W4 --> W5
        end
    end

    %% ─── LLM CONTEXT ───
    subgraph LLMContext["LLM Context Window"]
        direction TB
        CACHED["Cached Prefix<br/>(stable: @H + @I)"]
        VOLATILE["Volatile Layer<br/>(hot memory @M)"]
        ONDEMAND["On-Demand<br/>(loaded per request)"]
        CACHED --- VOLATILE --- ONDEMAND
    end

    %% ─── TAURI UI ───
    subgraph TauriUI["Tauri 2 Desktop App"]
        direction LR
        UI_PATH["Path input"]
        UI_COMPILE["Compile button"]
        UI_STATS["Stats dashboard<br/>(resources, hot, groups, tokens)"]
        UI_OUTPUT["Output viewer"]
        UI_SAVE["Save / Copy"]
        UI_PATH --> UI_COMPILE --> UI_STATS --> UI_OUTPUT --> UI_SAVE
    end

    %% ─── CONNECTIONS ───
    LOCAL --> S1
    GIT --> S3
    CONFIG --> P1
    CONFIG --> P3

    P4 --> HotEngine
    HotEngine --> E4
    E4 --> HotMemory

    E5 --> AIMFDoc
    AIMFDoc --> Sharding
    AIMFDoc --> PRS

    W2 --> VOLATILE
    W4 --> ONDEMAND
    W4 -.->|"reads from disk"| LOCAL
    CACHED -.->|"prompt cache hit"| LLMContext

    TauriUI -.->|"invokes"| Pipeline
    Pipeline -.->|"returns result"| TauriUI

    %% ─── STYLES ───
    style InputLayer fill:#f0f4f8,stroke:#2e5090,color:#1a1a2e
    style Pipeline fill:#e8f0fe,stroke:#2e5090,color:#1a1a2e
    style Stage1 fill:#dbeafe,stroke:#3b82f6,color:#1a1a2e
    style Stage2 fill:#dbeafe,stroke:#3b82f6,color:#1a1a2e
    style Stage3 fill:#dbeafe,stroke:#3b82f6,color:#1a1a2e
    style Stage4 fill:#dbeafe,stroke:#3b82f6,color:#1a1a2e
    style HotEngine fill:#fef3c7,stroke:#d97706,color:#1a1a2e
    style HotMemory fill:#fef3c7,stroke:#d97706,color:#1a1a2e
    style AIMFDoc fill:#f0fdf4,stroke:#2d8b4e,color:#1a1a2e
    style Sharding fill:#ecfdf5,stroke:#059669,color:#1a1a2e
    style ReaderSkill fill:#fff7ed,stroke:#ea580c,color:#1a1a2e
    style Parser fill:#ffedd5,stroke:#f97316,color:#1a1a2e
    style Workflow fill:#ffedd5,stroke:#f97316,color:#1a1a2e
    style LLMContext fill:#fce7f3,stroke:#be185d,color:#1a1a2e
    style TauriUI fill:#ede9fe,stroke:#7c3aed,color:#1a1a2e
